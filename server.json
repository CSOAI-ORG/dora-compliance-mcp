    "source": "github"
  },
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "dora-compliance-mcp",
      "version": "1.4.12",
      "runtimeHint": "python",
      "transport": {
        "type": "stdio"
      }
    }
  ],
  "websiteUrl": "https://meok.ai/dora-compliance-mcp",
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/CSOAI-ORG/dora-compliance-mcp/main/assets/icon.svg",
      "mimeType": "image/svg+xml",
      "sizes": [
        "256x256"
      ],
      "theme": "dark"
    }
